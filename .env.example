# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://user:password@localhost:5432/mpesa_gateway

# Redis — cache only (Daraja token storage)
REDIS_URL=redis://localhost:6379/0

# RabbitMQ — Celery broker
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Daraja — Platform credentials (used for Shared Till)
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_PASSKEY=
DARAJA_SHORTCODE=
DARAJA_ENV=sandbox

# Platform
PLATFORM_BASE_URL=https://yourdomain.com

# Encryption key for django-encrypted-model-fields
FIELD_ENCRYPTION_KEY=
